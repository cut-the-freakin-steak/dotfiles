    "success": "#faebff",
    "warning": "#ffaea4",
    "syntax.comment": "#ffffff",
    "syntax.string": "#faebff",
    "syntax.keyword": "#ebf0ff",
    "syntax.variable": "#ffffff",
    "syntax.attribute": "#ebf0ff",
    "syntax.property": "#000000",
    "syntax.function": "#ebf0ff",
